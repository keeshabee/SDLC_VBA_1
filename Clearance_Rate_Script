Sub ProcessReportReviewData()
    '=================================================================
    ' Purpose: Read completed reports from Data sheet
    '          Write to MASTER SHEET with proper date column
    ' User provides the date range for the week
    ' UPDATED: Dynamically detects report type columns
    '          Excludes the "Count" column (Total column)
    '=================================================================
    
    On Error GoTo ErrorHandler
    
    Dim wsData As Worksheet
    Dim wsMaster As Worksheet
    Dim startDate As String, endDate As String
    Dim dateHeader As String
    Dim targetCol As Long
    Dim lastRow As Long, i As Long, col As Long
    Dim county As String
    Dim totalCount As Long
    Dim reportColStart As Long, reportColEnd As Long
    Dim headerText As String
    
    ' Set worksheet references
    Set wsData = ThisWorkbook.Sheets("Data")
    Set wsMaster = ThisWorkbook.Sheets("MASTER SHEET")
    
    ' Get date range from user
    startDate = InputBox("Enter start date (Monday) in format M/D/YYYY:", _
                        "Start Date", "11/17/2025")
    If startDate = "" Then Exit Sub
    
    endDate = InputBox("Enter end date (Sunday) in format M/D/YYYY:", _
                      "End Date", "11/23/2025")
    If endDate = "" Then Exit Sub
    
    ' Create date header (format: M/D/YYYY)
    dateHeader = startDate
    
    ' Find or create column for this date in MASTER SHEET
    targetCol = FindOrCreateDateColumn(wsMaster, dateHeader)
    
    ' Initialize all counties to 0 in the target column
    Dim counties As Variant
    counties = GetAllCounties()
    
    For i = 0 To UBound(counties)
        wsMaster.Cells(i + 3, targetCol).Value = 0  ' Row 3 starts county data
    Next i
    
    '=================================================================
    ' DYNAMIC COLUMN DETECTION
    ' Find which columns contain report types
    ' Exclude the "Count" column (Total) - must be EXACTLY "Count"
    '=================================================================
    
    reportColStart = 2  ' Start at column B (after County Name in column A)
    reportColEnd = 1    ' Will find the last report column
    
    ' Find the last column with data in header row
    Dim lastDataCol As Long
    lastDataCol = wsData.Cells(1, wsData.Columns.Count).End(xlToLeft).Column
    
    ' Look for a column that is EXACTLY "Count" (the Total column)
    Dim totalColumnFound As Boolean
    totalColumnFound = False
    
    For col = 2 To lastDataCol  ' Start at column B
        headerText = Trim(wsData.Cells(1, col).Value)
        
        ' Check if this header is EXACTLY "Count" (case-insensitive)
        If UCase(headerText) = "COUNT" Then
            ' This is the Total column - exclude it
            reportColEnd = col - 1
            totalColumnFound = True
            Debug.Print "Found Total column 'Count' at position " & col
            Debug.Print "Will sum columns " & reportColStart & " to " & reportColEnd
            Exit For
        End If
    Next col
    
    ' If we didn't find a "Count" total column, use all columns up to the end
    If Not totalColumnFound Then
        reportColEnd = lastDataCol
        Debug.Print "No 'Count' total column found. Will sum all columns " & reportColStart & " to " & reportColEnd
    End If
    
    ' Ensure we have at least one report column
    If reportColEnd < reportColStart Then
        MsgBox "Error: No report type columns found in Data sheet." & vbCrLf & _
               "Expected columns starting at B with report counts.", vbCritical
        Exit Sub
    End If
    
    '=================================================================
    ' Read data from Data sheet and sum across all report type columns
    '=================================================================
    
    lastRow = wsData.Cells(wsData.Rows.Count, "A").End(xlUp).Row
    
    For i = 3 To lastRow  ' Start at row 3 (after headers)
        county = Trim(wsData.Cells(i, 1).Value)  ' Column A - County Name
        
        If county <> "" And UCase(county) <> "TOTAL FOR WEEK" Then
            totalCount = 0
            
            ' Sum all report type columns (dynamically determined)
            For col = reportColStart To reportColEnd
                If IsNumeric(wsData.Cells(i, col).Value) Then
                    totalCount = totalCount + wsData.Cells(i, col).Value
                End If
            Next col
            
            ' Debug output
            Debug.Print "County: " & county & " | Count: " & totalCount
            
            ' Write to MASTER SHEET
            Call WriteCountyData(wsMaster, county, targetCol, totalCount)
        End If
    Next i
    
    ' Calculate weekly total
    wsMaster.Cells(24, targetCol).Value = Application.WorksheetFunction.Sum(wsMaster.Range(wsMaster.Cells(3, targetCol), wsMaster.Cells(23, targetCol)))
    wsMaster.Cells(24, targetCol).Font.Bold = True
    
    MsgBox "Report Review data processed for week " & dateHeader & vbCrLf & _
           "Results written to MASTER SHEET, column " & targetCol & vbCrLf & _
           "Processed " & (reportColEnd - reportColStart + 1) & " report type columns", vbInformation
    Exit Sub
    
ErrorHandler:
    MsgBox "Error " & Err.Number & ": " & Err.Description, vbCritical
End Sub

