' =========================================================
' Sub 4 of 4: County-Level Summary
' Groups CalcData by County + Filing Year,
' calculates average days and backlog count per group
' =========================================================
 
Sub BuildCountySummary()
 
    Dim calcWS    As Worksheet
    Dim summWS    As Worksheet
    Dim lastRow   As Long
    Dim i         As Long
    Dim outRow    As Long
    Dim groupKey  As String
    Dim county    As String
    Dim yr        As String
    Dim daysVal   As Long
    Dim isOver    As String
 
    Dim dictCount   As Object
    Dim dictSum     As Object
    Dim dictBacklog As Object
    Dim k           As Variant
    Dim parts()     As String
    Dim rng         As Range

Set calcWS = ThisWorkbook.Sheets("CalcData")
 
' --- Delete old CountySummary and create a fresh one ---
    On Error Resume Next
    Application.DisplayAlerts = False
    ThisWorkbook.Sheets("CountySummary").Delete
    Application.DisplayAlerts = True
    On Error GoTo 0
    Set summWS = ThisWorkbook.Sheets.Add
    summWS.Name = "CountySummary"
 
    ' --- Initialize all three dictionaries ---
    Set dictCount   = CreateObject("Scripting.Dictionary")
    Set dictSum     = CreateObject("Scripting.Dictionary")
    Set dictBacklog = CreateObject("Scripting.Dictionary")
lastRow = calcWS.Cells(calcWS.Rows.Count, 1).End(xlUp).Row
 
    ' --- Loop through CalcData (data starts at row 2, row 1 is header) ---
    For i = 2 To lastRow
 
        county  = Trim(CStr(calcWS.Cells(i, 1).Value))  ' Col A: COUNTY
        yr      = Trim(CStr(calcWS.Cells(i, 3).Value))  ' Col C: Filed Year
        daysVal = calcWS.Cells(i, 6).Value         ' Col F: Days to Disposition
        isOver  = Trim(CStr(calcWS.Cells(i, 7).Value))  ' Col G: Over 365 Days?
 
        If county = "" Or yr = "" Then GoTo NextRow
 
        groupKey = county & "|" & yr  ' e.g. 'ATL|2023'
 
        If dictCount.Exists(groupKey) Then
            dictCount(groupKey) = dictCount(groupKey) + 1
            dictSum(groupKey) = dictSum(groupKey) + daysVal
        Else
            dictCount.Add groupKey, 1
            dictSum.Add groupKey, daysVal
            dictBacklog.Add groupKey, 0
        End If
 
        If UCase(isOver) = "YES" Then
            dictBacklog(groupKey) = dictBacklog(groupKey) + 1
        End If
 
NextRow:
    Next i
' --- Write header row to CountySummary ---
    outRow = 1
    summWS.Cells(outRow, 1) = "COUNTY"
    summWS.Cells(outRow, 2) = "YEAR"
    summWS.Cells(outRow, 3) = "Total Cases"
    summWS.Cells(outRow, 4) = "Avg Days to Disposition"
    summWS.Cells(outRow, 5) = "Cases Over 365 Days"
    outRow = 2
 
' --- Write one row per county+year combination ---
    For Each k In dictCount.Keys
        parts = Split(k, "|")   ' splits 'MID|2023' into parts(0)='MID' and parts(1)='2023'
        summWS.Cells(outRow, 1) = parts(0)   ' COUNTY
        summWS.Cells(outRow, 2) = parts(1)   ' YEAR
        summWS.Cells(outRow, 3) = dictCount(k)   ' Total Cases
        summWS.Cells(outRow, 4) = Round(dictSum(k) / dictCount(k), 0)   ' Avg Days
        summWS.Cells(outRow, 5) = dictBacklog(k)   ' Cases Over 365
        outRow = outRow + 1
    Next k
' --- Sort CountySummary by County A-Z, then Year low to high ---
    Set rng = summWS.Range("A1").CurrentRegion
    rng.Sort 
        Key1:=summWS.Columns(1), Order1:=xlAscending, _
        Key2:=summWS.Columns(2), Order2:=xlAscending, _
        Header:=xlYes
 
    MsgBox "CountySummary complete! " & (outRow - 2) & " rows written.", vbInformation
 
End Sub

